<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_text_block_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:hint="@string/text_block_content_label"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="8" />
        </com.google.android.material.textfield.TextInputLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_markdown_h1"
                    style="@style/Widget.MeowPrinter.MarkdownIconButton"
                    android:contentDescription="@string/markdown_helper_h1"
                    android:tooltipText="@string/markdown_helper_h1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_markdown_bold"
                    style="@style/Widget.MeowPrinter.MarkdownIconButton"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/markdown_helper_bold"
                    android:tooltipText="@string/markdown_helper_bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_markdown_italic"
                    style="@style/Widget.MeowPrinter.MarkdownIconButton"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/markdown_helper_italic"
                    android:tooltipText="@string/markdown_helper_italic" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_markdown_list"
                    style="@style/Widget.MeowPrinter.MarkdownIconButton"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/markdown_helper_list"
                    android:tooltipText="@string/markdown_helper_list" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_markdown_numbered_list"
                    style="@style/Widget.MeowPrinter.MarkdownIconButton"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/markdown_helper_numbered_list"
                    android:tooltipText="@string/markdown_helper_numbered_list" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_markdown_quote"
                    style="@style/Widget.MeowPrinter.MarkdownIconButton"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/markdown_helper_quote"
                    android:tooltipText="@string/markdown_helper_quote" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_markdown_table"
                    style="@style/Widget.MeowPrinter.MarkdownIconButton"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/markdown_helper_table"
                    android:tooltipText="@string/markdown_helper_table" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/text_block_alignment_label" />

        <Spinner
            android:id="@+id/spinner_text_block_alignment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/text_block_size_label" />

        <Spinner
            android:id="@+id/spinner_text_block_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/text_block_font_label" />

        <Spinner
            android:id="@+id/spinner_text_block_font"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
